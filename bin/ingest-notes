#!/usr/bin/env bash
set -euo pipefail

export PATH="/etc/profiles/per-user/$USER/bin:$PATH"

readonly vault="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/Notes"
readonly inbox="$vault/📥 Inbox.md"
readonly lockfile="/tmp/ingest-notes.lock"

# Prevent concurrent runs
if ! mkdir "$lockfile" 2>/dev/null; then
  echo "Already running, skipping."
  exit 0
fi
trap 'rmdir "$lockfile"' EXIT

# Nothing to do if inbox is empty or missing
if [ ! -s "$inbox" ]; then
  echo "Inbox is empty, nothing to ingest."
  exit 0
fi

cd "$vault"
claude --dangerously-skip-permissions "/ingest all"
