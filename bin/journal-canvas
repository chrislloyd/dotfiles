#!/usr/bin/env bash
set -euo pipefail

export PATH="/etc/profiles/per-user/$USER/bin:/opt/homebrew/bin:$PATH"

readonly vault="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/Notes"
readonly journal="$vault/Journal"
readonly canvas="$vault/§ Journal.canvas"
readonly lockfile="/tmp/journal-canvas.lock"

if ! mkdir "$lockfile" 2>/dev/null; then
  echo "Already running, skipping."
  exit 0
fi
trap 'rmdir "$lockfile"' EXIT

GRID=40
WIDTH=$((9 * GRID))
HEIGHT=$((12 * GRID))
GAP=$((1 * GRID))
ROW_HEIGHT=$((HEIGHT + GAP))
COL_WIDTH=$((WIDTH + GAP))

nodes="[]"
row=0

# Group journal entries by ISO week
ls "$journal" | grep -E '^[0-9]{4}-[0-9]{2}-[0-9]{2}' | grep '\.md$' | sort | while read -r file; do
  date_str="${file:0:10}"
  echo "$date_str $file"
done | awk '{
  cmd = "date -j -f %Y-%m-%d " $1 " +%G-%V 2>/dev/null"
  cmd | getline week
  close(cmd)
  print week, $0
}' | sort -k1,1 | awk -v w="$WIDTH" -v h="$HEIGHT" -v rh="$ROW_HEIGHT" -v cw="$COL_WIDTH" '
BEGIN {
  printf "{\"nodes\":["
  first = 1
  prev_week = ""
  row = -1
  col = 0
  n = 0
}
{
  week = $1
  file = $3
  for (i = 4; i <= NF; i++) file = file " " $i

  if (week != prev_week) {
    row++
    col = 0
    if (!first) printf ","
    first = 0
    # Week header node
    split(week, parts, "-")
    year = parts[1]
    wnum = parts[2]
    id = sprintf("%016x", n++)
    printf "{\"id\":\"%s\",\"x\":0,\"y\":%d,\"width\":%d,\"height\":%d,\"type\":\"text\",\"text\":\"# %s W%s\",\"color\":\"5\"}", id, row * rh, w, h, year, wnum
    prev_week = week
  }

  col++
  printf ","
  id = sprintf("%016x", n++)
  # Escape the file path for JSON
  gsub(/"/, "\\\"", file)
  printf "{\"id\":\"%s\",\"x\":%d,\"y\":%d,\"width\":%d,\"height\":%d,\"type\":\"file\",\"file\":\"Journal/%s\"}", id, col * cw, row * rh, w, h, file
}
END {
  printf "],\"edges\":[]}"
}' > "$canvas"

echo "Canvas regenerated at $(date)"
